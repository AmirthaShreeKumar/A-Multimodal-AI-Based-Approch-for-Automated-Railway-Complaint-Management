# Copy to .env and put your key AFTER the = on the same line (no space before the key).

#GOOGLE_API_KEY=

# Optional alias:
# GEMINI_API_KEY=

# OpenAI (optional text-only fallback)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# —— SOS multi-channel (any subset; at least one must be configured) ——

# Twilio (SMS + optional WhatsApp) — https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_PHONE_NUMBER=+16625551234
#
# WhatsApp (same Twilio account). Sandbox demo: whatsapp:+14155238886
# Join sandbox from your phone: send "join <word>" to +1 415 523 8886 (see Twilio WhatsApp sandbox page).
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#
# Phone numbers for SMS + WhatsApp (comma-separated). 10-digit India → +91 added.
# If unset, defaults to +919443081888.
# SOS_SMS_TO=9384374064
#
# Twilio Trial blocks multi-segment SMS (error 30044). Default SMS is one short line (~160 chars).
# After upgrading: SOS_SMS_LONG=true for full multi-line SMS (still capped at 1500 chars).
# SOS_SMS_MAX_CHARS=160

# Email alerts (SMTP). Gmail: use an App Password.
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=app-password
# MAIL_DEFAULT_SENDER=you@gmail.com
# SOS_EMAIL_TO=ops1@gmail.com,ops2@gmail.com

# Phone push without DLT: install "ntfy" app, subscribe to your topic, set same topic here.
# https://docs.ntfy.sh/
# SOS_NTFY_TOPIC=railmadad-demo-yourname
